---
import { Image } from 'astro:assets';
import zuricataImg from '@/assets/zuricata.png';
import TerminalBlink from '@components/islands/TerminalBlink';
import { FileText, FolderOpen, Check } from 'lucide-astro';
---

<section class="py-12 md:py-16">
  <div class="mx-auto max-w-5xl px-6 flex flex-col-reverse items-center gap-12 md:flex-row md:justify-between">
    <div class="flex-1">
      <p class="terminal-prompt mb-4 text-sm">$ whoami</p>

      <h1 class="text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
        zuricata<span class="text-magenta-dim">.dev</span>
        <TerminalBlink client:load />
      </h1>

      <p class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-sm text-text-ghost tracking-widest uppercase mb-8">
        <span class="inline-flex items-center gap-1"><Check size={14} class="text-accent" />AI-first</span>
        <span>·</span>
        <span class="inline-flex items-center gap-1"><Check size={14} class="text-accent" />open protocols</span>
        <span>·</span>
        <span class="inline-flex items-center gap-1"><Check size={14} class="text-accent" />real products</span>
      </p>

      <p class="max-w-xl text-lg text-text-secondary leading-relaxed mb-10">
        I build products with AI at the core — from tourism platforms on Lightning
        to legal AI agents. I automate everything else. If it can be built, I ship it.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-[--radius-card] bg-magenta-dim px-5 py-2.5 font-mono text-sm font-semibold text-text-primary no-underline transition-opacity hover:opacity-90"
        >
          <FileText size={16} />
          ~/blog
        </a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 rounded-[--radius-card] border border-border px-5 py-2.5 font-mono text-sm text-text-secondary no-underline transition-colors hover:border-accent hover:text-accent"
        >
          <FolderOpen size={16} />
          ~/projects
        </a>
      </div>
    </div>

    <div class="flex-shrink-0">
      <Image
        src={zuricataImg}
        alt="zuricata"
        width={400}
        height={400}
        class="rounded-full border-2 border-border"
      />
    </div>
  </div>
</section>
