const tools = Object.entries(icons).map(([key, svg]) => {
  const names: Record<string, string> = {
    claude: 'Claude',
    'claude-code': 'Claude Code',
    opencode: 'OpenCode',
    openclaw: 'OpenClaw',
    cloud: 'Cloud',
    linux: 'Linux',
    supabase: 'Supabase',
    nextjs: 'Next.js',
  };
  return { name: names[key], icon: svg };
});
---

<section class="marquee border-y border-border py-8">
  {[0, 1].map((i) => (
    <div class="marquee-group" aria-hidden={i === 1 ? 'true' : undefined}>
      {tools.map(({ name, icon }) => (
        <div class="marquee-item group" title={name}>
          <div class="flex h-10 w-10 items-center justify-center text-text-ghost transition-colors duration-300 group-hover:text-accent">
            <Fragment set:html={icon} />
          </div>
          <span class="mt-1.5 font-mono text-[10px] text-text-ghost transition-colors duration-300 group-hover:text-accent">
            {name}
          </span>
        </div>
      ))}
    </div>
  ))}
</section>

<style>
  .marquee {
    --gap: 3rem;
    display: flex;
    gap: var(--gap);
    overflow: hidden;
  }

  .marquee-group {
    display: flex;
    gap: var(--gap);
    flex-shrink: 0;
    min-width: 100%;
    justify-content: space-around;
    animation: scroll 25s linear infinite;
  }

  .marquee-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    cursor: default;
  }

  .marquee:hover .marquee-group {
    animation-play-state: paused;
  }

  @keyframes scroll {
    to {
      transform: translateX(calc(-100% - var(--gap)));
    }
  }
</style>
