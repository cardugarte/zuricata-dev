---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ui/ProjectCard.astro';
import { projects } from '@data/projects';

const active = projects.filter((p) => p.status === 'active');
const archived = projects.filter((p) => p.status === 'archived');
---

<BaseLayout title="Projects" description="Things I've built and contributed to.">
  <section class="py-16">
    <div class="section-container">
      <p class="section-heading">// projects</p>
      <h1 class="text-3xl md:text-4xl mb-10">Projects</h1>

      {active.length > 0 && (
        <div class="mb-12">
          <h2 class="font-mono text-sm text-text-ghost mb-4">active</h2>
          <div class="grid gap-4 md:grid-cols-2">
            {active.map((project) => (
              <ProjectCard
                title={project.title}
                description={project.description}
                url={project.url}
                repo={project.repo}
                tags={project.tags}
              />
            ))}
          </div>
        </div>
      )}

      {archived.length > 0 && (
        <div>
          <h2 class="font-mono text-sm text-text-ghost mb-4">archived</h2>
          <div class="grid gap-4 md:grid-cols-2">
            {archived.map((project) => (
              <ProjectCard
                title={project.title}
                description={project.description}
                url={project.url}
                repo={project.repo}
                tags={project.tags}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
